{
  "name": "drizzle-migration-lint",
  "version": "0.2.0",
  "description": "Catch drizzle-kit migrations that will lock or rewrite your production tables",
  "license": "MIT",
  "author": "Rodrigo Nogueira",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodrigobnogueira/drizzle-migration-lint.git"
  },
  "keywords": [
    "drizzle",
    "drizzle-kit",
    "migrations",
    "lint",
    "postgres",
    "zero-downtime",
    "strong-migrations"
  ],
  "bin": {
    "drizzle-migration-lint": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "docs/rules.md"
  ],
  "scripts": {
    "clean": "rimraf dist coverage .stryker-tmp tsconfig.build.tsbuildinfo",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.spec.json",
    "test": "TS_NODE_PROJECT=tsconfig.spec.json node --require ts-node/register --test test/unit/*.test.ts test/*.test.ts",
    "test:cov": "c8 --all --include \"src/**/*.ts\" --exclude \"src/types.ts\" --exclude \"src/index.ts\" --reporter text --reporter text-summary --reporter json-summary --reporter lcov --check-coverage --branches 100 --functions 100 --lines 100 --statements 100 npm test",
    "lint": "eslint --config eslint.config.mjs \"src/**/*.ts\" \"scripts/**/*.mjs\"",
    "complexity:check": "eslint --config eslint.complexity-check.config.mjs \"src/**/*.ts\"",
    "complexity:report": "node scripts/collect-cognitive-complexity.mjs",
    "fixtures:regen": "node scripts/fixtures-regen.mjs",
    "test:mutation": "stryker run",
    "test:mutant": "TS_NODE_PROJECT=tsconfig.spec.json node --require ts-node/register --test --test-force-exit test/unit/*.test.ts test/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@types/node": "^26.0.1",
    "@typescript-eslint/parser": "^8.62.0",
    "c8": "^11.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "packageManager": "npm@11.13.0",
  "dependencies": {
    "libpg-query": "^17.7.3"
  }
}
